# API keys
GEMINI_API_KEY=
LLAMA_CLOUD_API_KEY=

# Ingestion/chunking backends
PARSER_BACKEND=llamaparse
PARSER_STRICT_PAGE_MATCH=true
CHUNKER_VERSION=v1

# Docling parser tuning (used when PARSER_BACKEND=docling)
DOCLING_ENABLE_FORMULA_ENRICHMENT=1
DOCLING_GENERATE_PAGE_IMAGES=0
DOCLING_IMAGES_SCALE=1.5
DOCLING_CODEFORMULA_PRESET=codeformulav2
DOCLING_INJECT_FORMULAS_IN_MARKDOWN=1
DOCLING_DEVICE=cuda
DOCLING_PAGE_BATCH_SIZE=12
DOCLING_MIN_PAGE_BATCH_SIZE=1
DOCLING_ADAPTIVE_BATCHING=1
DOCLING_SET_PYTORCH_ALLOC_CONF=1
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# Model selection
LLM_BACKEND=gemini
LLM_MODEL=
LLM_BASE_URL=http://localhost:11434
LLM_TIMEOUT_S=120
GEMINI_MODEL=gemini-3-flash-preview

# Retrieval defaults
VECTOR_BACKEND=faiss
RETRIEVAL_MODE=hybrid
TOP_K=8
RETRIEVAL_QUERY_FUSION=true
RETRIEVAL_RRF_K0=60
RETRIEVAL_CANDIDATE_MULTIPLIER=4
RETRIEVAL_ENABLE_RERANK=true
RETRIEVAL_RERANK_POOL=40

# Answering defaults
ASK_MAX_CONTEXT_CHUNKS=6
ASK_MAX_CONTEXT_CHARS=12000
ASK_MIN_EVIDENCE_HITS=2
ASK_REQUIRE_CITATIONS=true
ASK_INCLUDE_NEIGHBOR_CHUNKS=true
ASK_NEIGHBOR_WINDOW=1
ASK_SHOW_EVIDENCE_DEFAULT=false
ASK_JSON_DEFAULT=false

# Agent loop bounds
AGENT_MAX_STEPS=8
AGENT_MAX_TOOL_CALLS=3
AGENT_MAX_RETRIEVAL_ROUNDS=2
AGENT_MIN_EVIDENCE_HITS=2

# Determinism
LLM_TEMPERATURE=0.0
PYTHONHASHSEED=0

# Local Day 1 Ollama example
# LLM_BACKEND=ollama
# LLM_MODEL=qwen3:8B
# LLM_BASE_URL=http://localhost:11434
